<?xml version="1.0" encoding="UTF-8"?>
<Справочники>
    {{- range $val := . }}
    <Контрагенты ИдКонтр="{{$val.RegId}}" П000000000007="{{ $val.ShortName}}">
        {{- if eq $val.Country "643"}}
        <Резидент>
            <П000000000008>
                <КодСтраны>{{ $val.Country }}</КодСтраны>
                <Индекс/>
                <КодРегион>{{ $val.Region }}</КодРегион>
                <Район/>
                <Город/>
                <НаселПункт/>
                <Улица/>
                <Дом/>
                <Корпус/>
                <Литера/>
                <Кварт/>
            </П000000000008>
            <ЮЛ П000000000009="{{$val.Inn}}" П000000000010="{{$val.Kpp}}" />
        {{- if eq "Производитель" $val.Type }}
            <Производитель value="True" />
        {{- else}}
            {{- if eq "Импортер" $val.Type }}
            <Производитель value="True" />
            {{- else}}
            <Производитель value="False" />
            {{- end}}
        {{- end}}
            <Перевозчик value="False" />
        </Резидент>
        {{- else}}
        <Резидент>
            <П000000000008>
                <КодСтраны>{{ $val.Country }}</КодСтраны>
                <Индекс/>
                <КодРегион>00</КодРегион>
                <Район/>
                <Город/>
                <НаселПункт/>
                <Улица/>
                <Дом/>
                <Корпус/>
                <Литера/>
                <Кварт/>
            </П000000000008>
            <ЮЛ П000000000009="{{$val.Inn}}" П000000000010="{{$val.Kpp}}" />
        {{- if eq "Производитель" $val.Type }}
            <Производитель value="True" />
        {{- else}}
            {{- if eq "Импортер" $val.Type }}
            <Производитель value="True" />
            {{- else}}
            <Производитель value="False" />
            {{- end}}
        {{- end}}
            <Перевозчик value="False" />
        </Резидент>
        {{/* <Иностр П000000000081="{{ $val.Country }}" П000000000082="{{ $val.Description }}" УчРегНомер="{{$val.RegId}}"/> */}}
        {{- end}}
    </Контрагенты>
    {{- end}}
</Справочники>